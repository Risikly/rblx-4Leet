--cheat lib
local drawingPool = {}
local drawingClasses = {}
local drawingIndex = 0

local function getDrawing(class)
    drawingIndex += 1
    local obj = drawingPool[drawingIndex]
    if obj and drawingClasses[drawingIndex] == class then
        obj.Visible = true
        return obj
    end
    -- wrong type or doesn't exist, replace it
    if obj then obj:Remove() end
    local new = Drawing.new(class)
    drawingPool[drawingIndex] = new
    drawingClasses[drawingIndex] = class
    return new
end

local function beginFrame()
    drawingIndex = 0
end

local function endFrame()
    -- hide any leftover drawings from previous frame
    for i = drawingIndex + 1, #drawingPool do
        drawingPool[i].Visible = false
    end
end

local function drawLine(from, to, color, thickness)
    local line = getDrawing("Line")
    line.From = from
    line.To = to
    line.Color = color or Color3.new(1, 0, 0)
    line.Thickness = thickness or 1.5
    line.Visible = true
end

local function drawText(position, text, color)
    local txt = getDrawing("Text")
    txt.Position = position
    txt.Text = text
    txt.Color = color or Color3.new(1, 1, 1)
    txt.Size = 12
    txt.Font = 2
    txt.Visible = true
end

local function clearDrawings()
    for i, d in ipairs(drawingPool) do
        d:Remove()
        drawingPool[i] = nil
    end
    drawingIndex = 0
end

local function getBoundingBox(cframe, size)
        size = size or Vector3.new(4, 6, 4)
    local half = size / 2

    local corners = {
        cframe * Vector3.new(-half.X, -half.Y, -half.Z),
        cframe * Vector3.new( half.X, -half.Y, -half.Z),
        cframe * Vector3.new( half.X,  half.Y, -half.Z),
        cframe * Vector3.new(-half.X,  half.Y, -half.Z),
        cframe * Vector3.new(-half.X, -half.Y,  half.Z),
        cframe * Vector3.new( half.X, -half.Y,  half.Z),
        cframe * Vector3.new( half.X,  half.Y,  half.Z),
        cframe * Vector3.new(-half.X,  half.Y,  half.Z),
    }

    local minX, minY = math.huge, math.huge
    local maxX, maxY = -math.huge, -math.huge

    for _, corner in ipairs(corners) do
        local screenPos, onScreen = cam:WorldToViewportPoint(corner)
        if not onScreen then return end
        minX = math.min(minX, screenPos.X)
        minY = math.min(minY, screenPos.Y)
        maxX = math.max(maxX, screenPos.X)
        maxY = math.max(maxY, screenPos.Y)
    end

    local topLeft = Vector2.new(minX, minY)
    local topRight = Vector2.new(maxX, minY)
    local bottomRight = Vector2.new(maxX, maxY)
    local bottomLeft = Vector2.new(minX, maxY)
    return topLeft, topRight, bottomRight, bottomLeft
end



local function drawBox(topLeft, topRight, bottomRight, bottomLeft, color)
    drawLine(topLeft, topRight, color)
    drawLine(topRight, bottomRight, color)
    drawLine(bottomRight, bottomLeft, color)
    drawLine(bottomLeft, topLeft, color)
end

local function drawHealthBar(bottomPos, topPos, health, maxhealth)
    local healthPercent = math.clamp(health / maxhealth, 0, 1)
    if healthPercent == 1 then return end -- don't draw if at full health
    local hpText = health .. "/" .. maxhealth
    local barEnd = bottomPos:Lerp(topPos, healthPercent)
    local barColor = Color3.fromRGB(
        math.floor((1 - healthPercent) * 255),
        math.floor(healthPercent * 211),
        0
    )

    drawLine(bottomPos, barEnd, barColor, 2)
    local textSize = TextService:GetTextSize(hpText, 12, Enum.Font.SourceSans, Vector2.new())
    drawText(Vector2.new(topPos.X - textSize.X - padding, topPos.Y), hpText, Color3.new(1, 1, 1))
end

local function getDistance(cframe)
    return math.floor((cam.CFrame.Position - cframe.Position).Magnitude)
end

local function getCrosshairDistance(char)
    local head = char and char:FindFirstChild("Head")
    if not head then return math.huge end

    local screenPos, onScreen = cam:WorldToViewportPoint(head.Position)
    if not onScreen then
        return math.huge -- ignore off-screen targets
    end

    local center = cam.ViewportSize / 2
    return (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
end

local function isStringInList(str, list)
    for _, v in ipairs(list) do
        if v == str then
            return true
        end
    end
    return false
end



