local function hotkey(parent, text, default_key, ishold, i_ypos, callback, ignoreHoldState)
    local posy = padding + (defaultsize * i_ypos) + (padding * i_ypos)

    local currentKey = default_key

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 120, 0, defaultsize)
    label.Position = UDim2.new(0, padding, 0, posy)
    label.Text = text
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.SourceSans
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = parent


    local frame = Instance.new("TextButton")
    frame.Size = UDim2.new(0, 60, 0, defaultsize)
    frame.Position = UDim2.new(1, -padding - 60, 0, posy)
    frame.Text = currentKey and currentKey.Name or "None"
    frame.BackgroundColor3 = Color3.fromRGB(40,40,40) Color3.fromRGB(60,60,60)
    frame.TextColor3 = Color3.new(1,1,1)
    frame.Font = Enum.Font.SourceSans
    frame.TextSize = 14
    frame.BorderSizePixel = 1
    frame.Parent = parent

    if not ignoreHoldState then
        frame.MouseButton2Click:Connect(function()
            ishold.hold = not ishold.hold
            if ishold.hold then
                frame.BackgroundColor3 = Color3.fromRGB(60,60,60)
            else
                frame.BackgroundColor3 = Color3.fromRGB(40,40,40)
            end
        end)
    end

    frame.MouseButton1Click:Connect(function()
        frame.Text = "..."

        local connection
        connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)

            -- Escape should always work
            if input.KeyCode == Enum.KeyCode.Escape then
                currentKey = nil
                frame.Text = "None"

                if callback then
                    callback(currentKey)
                end

                connection:Disconnect()
                return
            end

            if gameProcessed then return end

            if input.UserInputType == Enum.UserInputType.Keyboard then
                currentKey = input.KeyCode
                frame.Text = currentKey.Name

                if callback then
                    callback(currentKey)
                end

                connection:Disconnect()
            end
        end)
    end)

    return {
        get = function()
            return currentKey
        end,

        set = function(key)
            currentKey = key
            frame.Text = key and key.Name or "None"

            if callback then
                callback(currentKey)
            end
        end
    }
end


