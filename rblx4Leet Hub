local suffixes = {
    K = 1e3,
    M = 1e6,
    B = 1e9,
    T = 1e12,
    QA = 1e15,
    QI = 1e18,
    SX = 1e21
}
local function parseShecklesgag(text)
    if not text or text == "" then return 0 end

    -- remove spaces and currency symbol if exists
    text = text:gsub("[,%s¢]", "")

    -- find number + suffix
    local number, suffix = text:match("([%d%.]+)(%a*)")

    number = tonumber(number)
    if not number then return 0 end

    if suffix ~= "" then
        suffix = suffix:upper()
        local multiplier = suffixes[suffix]
        if multiplier then
            return number * multiplier
        end
    end

    return number
end

