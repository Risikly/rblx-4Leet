local function parseMoneypvb(str)
    -- remove $
    str = str:gsub("%$", ""):gsub(",", ""):lower()

    -- get number and suffix
    local num, suffix = str:match("([%d%.]+)(%a?)")
    num = tonumber(num)

    local multipliers = {
        k = 1e3,
        m = 1e6,
        b = 1e9,
        t = 1e12
    }

    if suffix and multipliers[suffix] then
        num = num * multipliers[suffix]
    end

    return num
end

