local function slider(parent, text, min, max, default, i_ypos, callback)
    min = min or 0
    max = max or 100
    default = default or min

    local posy = padding + (defaultsize * i_ypos) + (padding * i_ypos)

    local sliderWidth = 120
    local sliderHeight = 6
    local knobSize = 14

    local value = default
    local dragging = false

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 120, 0, defaultsize)
    label.Position = UDim2.new(0, padding, 0, posy)
    label.Text = text
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.SourceSans
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = parent


    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(0, 40, 0, defaultsize)
    valueLabel.Position = UDim2.new(1, -padding - 40, 0, posy)
    valueLabel.Text = tostring(default)
    valueLabel.TextColor3 = Color3.new(1,1,1)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Font = Enum.Font.SourceSans
    valueLabel.TextSize = 14
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.Parent = parent


    local sliderBg = Instance.new("Frame")
    sliderBg.Size = UDim2.new(0, sliderWidth, 0, sliderHeight)
    sliderBg.Position = UDim2.new(1, -sliderWidth - padding - 40, 0, posy + (defaultsize - sliderHeight) / 2)
    sliderBg.BackgroundColor3 = Color3.fromRGB(40,40,40)
    sliderBg.BorderSizePixel = 1
    sliderBg.Parent = parent


    local sliderFill = Instance.new("Frame")
    sliderFill.Size = UDim2.new(0,0,1,0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(18,179,112)
    sliderFill.BorderSizePixel = 0
    sliderFill.Parent = sliderBg


    local knob = Instance.new("TextButton")
    knob.Size = UDim2.new(0, knobSize, 0, knobSize)
    knob.BackgroundColor3 = Color3.fromRGB(200,200,200)
    knob.Text = ""
    knob.BorderSizePixel = 1
    knob.AutoButtonColor = false
    knob.Parent = sliderBg


    local function updateVisual(val)
        local pct = (val - min) / (max - min)
        sliderFill.Size = UDim2.new(pct,0,1,0)
        knob.Position = UDim2.new(pct,-knobSize/2,0.5,-knobSize/2)
        valueLabel.Text = tostring(val)
    end

    updateVisual(value)


    knob.MouseButton1Down:Connect(function()
        dragging = true
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)


    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then

            local absPos = sliderBg.AbsolutePosition.X
            local absSize = sliderBg.AbsoluteSize.X
            local mouseX = input.Position.X

            local pct = math.clamp((mouseX - absPos) / absSize, 0, 1)

            value = math.floor(min + (max - min) * pct)

            updateVisual(value)

            if callback then
                callback(value)
            end
        end
    end)
end

local function combobox(parent, text, options, default, i_ypos, callback)
    local posy = padding + (defaultsize * i_ypos) + (padding * i_ypos)

    local selected = default or options[1] or ""
    local open = false

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 120, 0, defaultsize)
    label.Position = UDim2.new(0, padding, 0, posy)
    label.Text = text
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.SourceSans
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = parent


    local dropWidth = 120
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(0, dropWidth, 0, defaultsize)
    button.Position = UDim2.new(1, -padding - dropWidth, 0, posy)
    button.Text = tostring(selected)
    button.BackgroundColor3 = Color3.fromRGB(40,40,40)
    button.TextColor3 = Color3.new(1,1,1)
    button.Font = Enum.Font.SourceSans
    button.TextSize = 14
    button.BorderSizePixel = 1
    button.Parent = parent


    local dropdownFrame = Instance.new("Frame")
    dropdownFrame.Size = UDim2.new(0, dropWidth, 0, #options * defaultsize)
    dropdownFrame.Position = UDim2.new(1, -padding - dropWidth, 0, posy + defaultsize)
    dropdownFrame.BackgroundColor3 = Color3.fromRGB(30,30,30)
    dropdownFrame.BorderSizePixel = 1
    dropdownFrame.ZIndex = 10
    dropdownFrame.Visible = false
    dropdownFrame.Parent = parent

    for i, option in ipairs(options) do
        local optBtn = Instance.new("TextButton")
        optBtn.Size = UDim2.new(1, 0, 0, defaultsize)
        optBtn.Position = UDim2.new(0, 0, 0, (i - 1) * defaultsize)
        optBtn.Text = tostring(option)
        optBtn.BackgroundColor3 = Color3.fromRGB(40,40,40)
        optBtn.TextColor3 = Color3.new(1,1,1)
        optBtn.Font = Enum.Font.SourceSans
        optBtn.TextSize = 14
        optBtn.BorderSizePixel = 0
        optBtn.ZIndex = 11
        optBtn.Parent = dropdownFrame

        optBtn.MouseButton1Click:Connect(function()
            selected = option
            button.Text = tostring(option)
            dropdownFrame.Visible = false
            open = false

            if callback then
                callback(selected)
            end
        end)
    end

    button.MouseButton1Click:Connect(function()
        open = not open
        dropdownFrame.Visible = open
    end)

    return {
        get = function()
            return selected
        end,

        set = function(value)
            selected = value
            button.Text = tostring(value)

            if callback then
                callback(selected)
            end
        end
    }
end

local function multiselectbox(parent, text, options, default, i_ypos, callback)
    local posy = padding + (defaultsize * i_ypos) + (padding * i_ypos)

    local selected = {}
    if default then
        for _, v in ipairs(default) do
            selected[v] = true
        end
    end

    local open = false

    local function getSelectedList()
        local t = {}
        for _, opt in ipairs(options) do
            if selected[opt] then
                table.insert(t, opt)
            end
        end
        return t
    end

    local function updateText(button)
        local list = getSelectedList()
        if #list == 0 then
            button.Text = "None"
        else
            button.Text = table.concat(list, ", ")
        end
    end

    -- LABEL
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 120, 0, defaultsize)
    label.Position = UDim2.new(0, padding, 0, posy)
    label.Text = text
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.SourceSans
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = parent

    -- BUTTON
    local dropWidth = 120
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(0, dropWidth, 0, defaultsize)
    button.Position = UDim2.new(1, -padding - dropWidth, 0, posy)
    button.BackgroundColor3 = Color3.fromRGB(40,40,40)
    button.TextColor3 = Color3.new(1,1,1)
    button.Font = Enum.Font.SourceSans
    button.TextSize = 14
    button.BorderSizePixel = 1
    button.Parent = parent

    -- DROPDOWN
    local dropdownFrame = Instance.new("Frame")
    dropdownFrame.Size = UDim2.new(0, dropWidth, 0, #options * defaultsize)
    dropdownFrame.Position = UDim2.new(1, -padding - dropWidth, 0, posy + defaultsize)
    dropdownFrame.BackgroundColor3 = Color3.fromRGB(30,30,30)
    dropdownFrame.BorderSizePixel = 1
    dropdownFrame.ZIndex = 10
    dropdownFrame.Visible = false
    dropdownFrame.Parent = parent

    -- OPTIONS
    for i, option in ipairs(options) do
        local optBtn = Instance.new("TextButton")
        optBtn.Size = UDim2.new(1, 0, 0, defaultsize)
        optBtn.Position = UDim2.new(0, 0, 0, (i - 1) * defaultsize)
        optBtn.BackgroundColor3 = Color3.fromRGB(40,40,40)
        optBtn.TextColor3 = Color3.new(1,1,1)
        optBtn.Font = Enum.Font.SourceSans
        optBtn.TextSize = 14
        optBtn.BorderSizePixel = 0
        optBtn.ZIndex = 11
        optBtn.Parent = dropdownFrame

        local function updateOptionText()
            local prefix = selected[option] and "[x] " or "[ ] "
